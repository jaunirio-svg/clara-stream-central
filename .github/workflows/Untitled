<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CLARA STREAMING | PREMIUM</title>
    <script src="https://cdn.jsdelivr.net/npm/hls.js@latest"></script>
    <style>
        :root {
            --gold: #D4AF37;
            --black: #0a0a0a;
            --gray: #1a1a1a;
        }

        body {
            background-color: var(--black);
            color: white;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            margin: 0;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        header {
            width: 100%;
            padding: 20px 0;
            text-align: center;
            border-bottom: 2px solid var(--gold);
            box-shadow: 0 0 15px rgba(212, 175, 55, 0.3);
        }

        h1 {
            color: var(--gold);
            letter-spacing: 4px;
            margin: 0;
            text-transform: uppercase;
        }

        #player-container {
            width: 90%;
            max-width: 1000px;
            margin: 30px 0;
            border: 2px solid var(--gold);
            border-radius: 10px;
            overflow: hidden;
            background: #000;
        }

        video {
            width: 100%;
            aspect-ratio: 16/9;
        }

        #channel-list {
            width: 90%;
            max-width: 1000px;
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
            gap: 15px;
            padding: 20px;
        }

        .channel-card {
            background: var(--gray);
            border: 1px solid #333;
            padding: 15px;
            text-align: center;
            border-radius: 8px;
            cursor: pointer;
            transition: 0.3s;
            color: var(--gold);
            font-weight: bold;
        }

        .channel-card:hover {
            border-color: var(--gold);
            background: #252525;
            transform: translateY(-5px);
        }

        .status-bar {
            font-size: 0.8em;
            color: #888;
            margin-top: 10px;
        }
    </style>
</head>
<body>

<header>
    <h1>CLARA STREAMING</h1>
    <div class="status-bar">SISTEMA PREMIUM • ONLINE</div>
</header>

<div id="player-container">
    <video id="video" controls autoplay></video>
</div>

<div id="channel-list" id="list">
    </div>

<script>
    // LISTA DE CANAIS (Você pode adicionar mais aqui depois)
    const channels = [
        { name: "SBT", url: "https://stmv1.v3v8.com.br/sbt/sbt/playlist.m3u8" },
        { name: "RECORD NEWS", url: "https://rnews.fabricahost.com.br/rnews/rnews/playlist.m3u8" },
        { name: "CNN BRASIL", url: "https://binge-cnn-brasil-1-br.samsung.wurl.com/playlist.m3u8" },
        { name: "CANAL CLIENTE", url: "https://stream.p2pcloud.live/canalcliente/index.m3u8" }
    ];

    const video = document.getElementById('video');
    const listContainer = document.getElementById('channel-list');

    // Função para carregar o vídeo
    function playChannel(url) {
        if (Hls.isSupported()) {
            const hls = new Hls();
            hls.loadSource(url);
            hls.attachMedia(video);
            hls.on(Hls.Events.MANIFEST_PARSED, function() {
                video.play();
            });
        } else if (video.canPlayType('application/vnd.apple.mpegurl')) {
            video.src = url;
            video.addEventListener('loadedmetadata', function() {
                video.play();
            });
        }
    }

    // Criar os botões de canais
    channels.forEach(ch => {
        const div = document.createElement('div');
        div.className = 'channel-card';
        div.innerText = ch.name;
        div.onclick = () => playChannel(ch.url);
        listContainer.appendChild(div);
    });

    // Iniciar com o primeiro canal
    playChannel(channels[0].url);
</script>

</body>
</html>
